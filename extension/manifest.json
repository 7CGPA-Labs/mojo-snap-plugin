{
  "manifest_version": 3,
  "name": "Retro Console",
  "version": "1.0.0",
  "description": "Play your local retro games directly in your browser with physical gamepad mapping.",
  "author": "7CGPA-Labs",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "shared/logo96.png"
  },
  "icons": {
    "96": "shared/logo96.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "shared/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
